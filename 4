def divisibility(tuples_list,K):
    return [tup for tup in tuples_list if all(element%K==0 for element in tup)]

tuples_list = [(6, 24, 12), (60, 12, 6), (12, 18, 21)]
K = 6
result = divisibility(tuples_list,K)
print(f"Tuples where all elements are divisible by {K}: {result}")    

def uppercase(test_list):
    return [tup for tup in test_list if all(elem.isupper() for elem in tup)]
test_list = [("GFG", "IS", "BEST"), ("GFg", "AVERAGE"), ("GfG",), ("Gfg", "CS")]
result = uppercase(test_list)
print(f"Tuples with all uppercase characters: {result}")

def count_occurrences(input_tuple, input_list):
    return sum(input_tuple.count(item) for item in input_list)
input_tuple = ('a', 'a', 'c', 'b', 'd')
input_list = ['a', 'b']
result = count_occurrences(input_tuple, input_list)
print(f"Total occurrences of list items in the tuple: {result}")
